{
  "name": "@birdie/gps51-web-sync",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "auth": "tsx src/auth/bootstrap.ts",
    "discover": "tsx src/browser/discovery.ts",
    "discover:live": "tsx src/browser/live-discovery.ts",
    "discover:subscription": "tsx src/browser/subscription-discovery.ts",
    "sync:live:dry": "tsx src/worker/live-sync-cli.ts dry",
    "sync:live:once": "tsx src/worker/live-sync-cli.ts once",
    "sync:live": "tsx src/worker/live-sync-cli.ts live",
    "sync:inventory:dry": "tsx src/worker/inventory-sync-cli.ts dry",
    "sync:inventory": "tsx src/worker/inventory-sync-cli.ts sync",
    "reconcile:inventory": "tsx src/worker/inventory-sync-cli.ts reconcile",
    "sync:status:bootstrap:dry": "tsx src/worker/status-bootstrap-cli.ts dry",
    "sync:status:bootstrap": "tsx src/worker/status-bootstrap-cli.ts sync",
    "discover:status-source": "tsx src/browser/status-source-discovery.ts",
    "discover:status-dom": "tsx src/browser/status-dom-discovery.ts",
    "discover:status-model": "tsx src/browser/status-model-discovery.ts",
    "discover:status-filter": "tsx src/browser/status-filter-discovery.ts",
    "discover:device-telemetry": "tsx src/browser/device-telemetry-discovery.ts",
    "discover:position-refresh": "tsx src/browser/position-refresh-discovery.ts",
    "discover:position-source": "tsx src/browser/position-source-discovery.ts",
    "sync:status:dom:dry": "tsx src/worker/status-dom-sync-cli.ts dry",
    "sync:status:dom": "tsx src/worker/status-dom-sync-cli.ts sync",
    "sync:status:tree:dry": "tsx src/worker/status-tree-sync-cli.ts dry",
    "sync:status:tree": "tsx src/worker/status-tree-sync-cli.ts sync",
    "sync:positions:tree:dry": "tsx src/worker/positions-tree-sync-cli.ts dry",
    "sync:positions:tree": "tsx src/worker/positions-tree-sync-cli.ts sync",
    "sync:positions:cache:dry": "tsx src/worker/position-cache-sync-cli.ts dry",
    "sync:positions:cache": "tsx src/worker/position-cache-sync-cli.ts sync",
    "sync": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "dotenv": "^17.4.2",
    "fastify": "^5.3.3",
    "pino": "^9.7.0",
    "playwright": "1.60.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.19.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
