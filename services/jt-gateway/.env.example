NODE_ENV=production
GATEWAY_INSTANCE_ID=birdie-gateway-01

JT808_BIND_HOST=0.0.0.0
JT808_TCP_PORT=6808
JT808_ENABLE_UDP=false
JT808_UDP_PORT=6808
JT808_SOCKET_IDLE_SECONDS=180
JT808_MAX_FRAME_BYTES=65535
JT808_ALLOW_AUTO_REGISTRATION=false

JT1078_BIND_HOST=0.0.0.0
JT1078_TCP_PORT=6809
JT1078_ENABLE_UDP=false
JT1078_UDP_PORT=6810
JT1078_MAX_PACKET_BYTES=65535

PUBLIC_GATEWAY_IPV4=
PUBLIC_GATEWAY_DOMAIN=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

COMMAND_POLL_INTERVAL_MS=250
COMMAND_ACK_TIMEOUT_MS=10000
COMMAND_MAX_RETRIES=3

MEDIAMTX_RTSP_URL=rtsp://mediamtx:8554
MEDIAMTX_HLS_BASE_URL=http://localhost:8888
FFMPEG_PATH=ffmpeg
H265_TRANSCODE_TO_H264=true

STREAM_TOKEN_SECRET=change-me-in-production
HEALTH_HTTP_PORT=8090
LOG_LEVEL=info
